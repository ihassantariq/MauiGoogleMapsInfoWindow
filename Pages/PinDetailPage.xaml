<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiGoogleMapsInfoWindow.Pages.PinDetailPage"
             Title="Place Details">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero Image — source set in code-behind from PlacePin.ImageUrl -->
            <Image x:Name="HeroImage"
                   Aspect="AspectFill"
                   HeightRequest="260"
                   BackgroundColor="#E0E0E0" />

            <!-- Content Card -->
            <Border StrokeShape="RoundRectangle 24,24,0,0"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Margin="0,-24,0,0"
                    Padding="24,28,24,40">

                <VerticalStackLayout Spacing="16">

                    <!-- Name & Category -->
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="PlaceName"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="&#xf3c5;"
                                   FontFamily="FASolid"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label x:Name="PlaceCategory"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Rating & Hours -->
                    <HorizontalStackLayout Spacing="20">
                        <!-- Rating -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}"
                                StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                Padding="12,8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf005;"
                                       FontFamily="FASolid"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Label x:Name="PlaceRating"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Opening Hours -->
                        <Border BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                                StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                Padding="12,8">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf017;"
                                       FontFamily="FASolid"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Label x:Name="PlaceHours"
                                       FontSize="13"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1B5E20, Dark=#A5D6A7}" />
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                             Margin="0,4" />

                    <!-- Description -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="About"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                        <Label x:Name="PlaceDescription"
                               FontSize="15"
                               LineHeight="1.5"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                    </VerticalStackLayout>

                    <!-- Address -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#212121}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            Padding="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="&#xf3c5; Address"
                                   FontFamily="FASolid"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Label x:Name="PlaceAddress"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Coordinates -->
                    <Border BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            Padding="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="&#xf279; Coordinates"
                                   FontFamily="FASolid"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0D47A1, Dark=#90CAF9}" />
                            <Label x:Name="PlaceCoordinates"
                                   FontSize="14"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#BBDEFB}" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
