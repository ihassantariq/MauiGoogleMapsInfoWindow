<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiGoogleMapsInfoWindow.Controls.PinInfoWindow"
             x:Name="this">
    <VerticalStackLayout Spacing="0" Padding="0" Margin="0">

        <Border BackgroundColor="White"
                StrokeThickness="1"
                Stroke="LightGray"
                StrokeShape="RoundRectangle 16"
                Padding="0"
                WidthRequest="380">

            <Grid ColumnDefinitions="12,*">

                <BoxView Grid.Column="0"
                         WidthRequest="12"
                         BackgroundColor="#512BD4"
                         VerticalOptions="Fill"
                         HorizontalOptions="Start"
                         CornerRadius="3"/>

                <Grid Grid.Column="1"
                      Padding="14,14,14,14"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="8">

                    <Label Grid.Row="0"
                           Text="{Binding PlaceName}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"
                           VerticalOptions="Center"/>

                    <Label Grid.Row="1"
                           Text="{Binding Address}"
                           FontSize="13"
                           TextColor="#666666"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"/>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto,2*"
                          ColumnSpacing="10">

                        <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Start" Spacing="6">
                            <Label Text="&#xf3c5;" FontFamily="FASolid" FontSize="14" TextColor="#512BD4" VerticalOptions="Center"/>
                            <Label Text="{Binding Category}" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1A1A1A" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="6">
                            <Label Text="&#xf005;" FontFamily="FASolid" FontSize="14" TextColor="#F5A623" VerticalOptions="Center"/>
                            <Label Text="{Binding Rating}" FontSize="14" FontAttributes="Bold"
                                   TextColor="#1A1A1A" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Column="2" HorizontalOptions="End" Spacing="6">
                            <Label Text="&#xf017;" FontFamily="FASolid" FontSize="14" TextColor="#666666" VerticalOptions="Center"/>
                            <Label Text="{Binding OpeningHours}" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A1A" VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"/>
                        </HorizontalStackLayout>

                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Polygon Points="0,0 28,0 14,18"
                 Fill="White"
                 StrokeThickness="0"
                 Margin="0,-1,0,0"
                 HorizontalOptions="Center"
                 VerticalOptions="Start"/>

    </VerticalStackLayout>
</ContentView>
